# Virtualenvs
s_i_triage/
.venv/
venv/

# Python
__pycache__/
*.py[cod]

# Flask / SQLite
BE/instance/
*.db

# UC2 / RAG runtime artifacts — regenerated on upload, never committed
BE/uploads/*
!BE/uploads/.gitkeep
BE/chroma_db/*
!BE/chroma_db/.gitkeep

# Local secrets — real env values never get committed (.env.example is the template)
.env
*.env
!*.env.example

# Test / tooling
.pytest_cache/

.claude/
