# Base URL for the Flask backend API.
# Leave empty to use same-origin relative requests (recommended in dev, where
# Vite proxies /api -> http://localhost:5000, and in prod when served behind
# the same domain / reverse proxy).
VITE_API_BASE_URL=

# Dev-only: where Vite should proxy /api and /health requests.
VITE_PROXY_TARGET=http://localhost:5000
