# --- Local development needs NONE of these ---
# Leaving everything unset runs Ollama (qwen2.5:3b) + SQLite, with debug on.

# --- Production ---
# Copy this file to .env (which is gitignored) and fill in real values, or set
# these in your host's dashboard. Never commit real secrets to this example.
APP_ENV=production

# Hosted LLM (any OpenAI-compatible API; Groq shown).
# Create a free key at https://console.groq.com
LLM_PROVIDER=openai
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.1-8b-instant

# Persistent database (free Postgres: Supabase). Use the Session pooler string
# (host ...pooler.supabase.com, port 5432, user postgres.<project-ref>).
DATABASE_URI=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Allowed frontend origin(s), comma-separated. No trailing slash.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# --- UC2: RAG knowledge base (self-hosted, optional — sane local defaults) ---
# RAG always talks to a self-hosted Ollama (chat + embeddings), never a hosted API.
OLLAMA_BASE_URL=http://localhost:11434
# Chat model for grounded answers; defaults to the same model UC1 uses.
RAG_CHAT_MODEL=qwen2.5:3b
# Embedding model — run `ollama pull nomic-embed-text`.
EMBEDDING_MODEL=nomic-embed-text
# Retrieval: a chunk counts as relevant only at/above this cosine similarity;
# below it for all chunks, the answer is "not in the knowledge base".
SIMILARITY_THRESHOLD=0.45
TOP_K=5
# Where uploads + the Chroma index live. NOTE: free hosts have ephemeral disks,
# so for a persistent KB mount a disk or point these at durable storage.
UPLOAD_FOLDER=uploads
CHROMA_DIR=chroma_db
